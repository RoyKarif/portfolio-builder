# Database — Postgres connection string used by the backend.
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
# host=db (Docker service name) when running inside Docker Compose.
DATABASE_URL=postgresql://portfolio:portfolio@db:5432/portfolio_builder

# Postgres credentials — used by the db service to initialize itself.
# These must match what's in DATABASE_URL.
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=portfolio
POSTGRES_DB=portfolio_builder

# JWT — secret used to sign access tokens. MUST be replaced for production.
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-strong-random-string-at-least-32-bytes

# JWT algorithm. HS256 = symmetric (one server). Don't change unless you
# know why (see CLAUDE.md / spec for rationale).
JWT_ALGORITHM=HS256

# How long access tokens are valid (in minutes). 30 is a sensible default
# for an app without refresh tokens — short enough to limit damage if
# leaked, long enough not to annoy the user.
ACCESS_TOKEN_EXPIRE_MINUTES=30
